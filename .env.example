# ParolNet Environment Configuration
# Copy to .env and fill in values. Docker Compose loads this automatically.

# Analytics (1 = enabled, 0 = disabled)
PAROLNET_ANALYTICS=1

# TURN/STUN Server (optional — leave empty to disable)
# When configured, coturn starts alongside the relay server.
# Clients whose relay doesn't offer TURN fall back to parol.social's TURN.
# TURN_SECRET=your-shared-secret-here
# TURN_EXTERNAL_IP=your-server-public-ip
# TURN_REALM=your-domain.com
# TURN_DOMAIN=turn.your-domain.com
